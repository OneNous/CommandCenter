{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@shared-artsky": ["../design-mobile/src/lib/ArtSky.jsx"]
    }
  },
  "include": ["src", "electron", "vite.config.ts"],
  "exclude": ["electron.vite.config.ts", "dist", "dist-electron", "node_modules"]
}

